{
  "rewrites": [
    { "source": "/app", "destination": "/index.html" },
    { "source": "/api/:path*", "destination": "/api/:path*.js" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET,POST,OPTIONS" }
      ]
    }
  ],
  "github": {
    "silent": true
  }
}
